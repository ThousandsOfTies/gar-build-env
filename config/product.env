# GarVibeRemote product branch settings.
export GAR_PRODUCT_NAME=GarVibeRemote

# Vibe Remote needs PlatformIO for optional M5StickC firmware packaging, but it
# does not need a full ESP-IDF checkout during devspace bootstrap.
export GAR_INSTALL_ESP_IDF=0
export GAR_INSTALL_PLATFORMIO=1

export VIBE_REMOTE_REPO_DIR=sources/gar-vibe-ui
export VIBE_REMOTE_PACKAGE_DIR=sources/gar-vibe-ui/vibe-remote
export GAR_RUNTIME_DIR=sources/GaplessAgentRuntime
export GAR_TOOLS_DIR=sources/gar-tools
export PIO_ENV=m5stickc-plus2-vibe-min

export PRODUCT_BUILD_SCRIPT=scripts/product-build.sh
export PRODUCT_ARTIFACTS_SCRIPT=scripts/product-artifacts.sh
export PRODUCT_CLEAN_SCRIPT=scripts/product-clean.sh
export PRODUCT_ARTIFACT_MANIFEST=config/artifact-manifest.json

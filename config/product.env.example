# Copy this file to config/product.env on a product branch and uncomment only
# the settings that product needs.
#
# export GAR_PRODUCT_NAME=ExampleProduct
#
# Optional toolchains:
# export GAR_INSTALL_PLATFORMIO=1
# export GAR_INSTALL_ESP_IDF=1
# export GAR_ESP_IDF_VERSION=v5.3.1
#
# Optional product hooks:
# export PRODUCT_BUILD_SCRIPT=scripts/product-build.sh
# export PRODUCT_ARTIFACTS_SCRIPT=scripts/product-artifacts.sh
# export PRODUCT_CLEAN_SCRIPT=scripts/product-clean.sh
